{
  "info": {
    "name": "UserDepartmentAPI – Spring Boot",
    "_postman_id": "a1b2c3d4-0001-0001-0001-000000000001",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Manual test collection for the spring-boot-mvc-hibernate project.\n\nRun requests in order within each folder. The CREATE requests save {{userId}} and {{deptId}} automatically via test scripts so subsequent requests work without manual copy-paste."
  },
  "variable": [
    { "key": "base_url",    "value": "http://localhost:8080" },
    { "key": "admin_user",  "value": "admin1" },
    { "key": "admin_pass",  "value": "admin1pass" },
    { "key": "user_user",   "value": "user1" },
    { "key": "user_pass",   "value": "user1pass" },
    { "key": "userId",      "value": "" },
    { "key": "deptId",      "value": "" }
  ],
  "item": [
    {
      "name": "Users CRUD",
      "item": [
        {
          "name": "GET All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"] },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{user_user}}" }, { "key": "password", "value": "{{user_pass}}" }] }
          }
        },
        {
          "name": "GET Users – paginated (page 0, size 5, sorted by lastName)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users?page=0&size=5&sort=lastName,asc",
              "host": ["{{base_url}}"],
              "path": ["api", "users"],
              "query": [
                { "key": "page", "value": "0", "description": "0-based page index" },
                { "key": "size", "value": "5", "description": "Items per page" },
                { "key": "sort", "value": "lastName,asc", "description": "Field and direction" }
              ]
            },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{user_user}}" }, { "key": "password", "value": "{{user_pass}}" }] },
            "description": "Spring MVC resolves Pageable from query params automatically.\nResponse wraps results in a Page<T> envelope:\n{\n  \"content\": [...],\n  \"page\": {\n    \"size\": 5,\n    \"number\": 0,\n    \"totalElements\": N,\n    \"totalPages\": M\n  }\n}\n\nOData equivalent: GET /odata/v4/UserDepartmentService/Users?$top=5&$skip=0&$orderby=lastName"
          }
        },
        {
          "name": "CREATE User (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('userId', json.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"country\": \"GERMANY\",\n  \"city\": \"Berlin\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"] },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{admin_user}}" }, { "key": "password", "value": "{{admin_pass}}" }] }
          }
        },
        {
          "name": "CREATE User – 403 as user1",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\",\n  \"email\": \"jane@example.com\",\n  \"country\": \"IRELAND\",\n  \"city\": \"Dublin\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"] },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{user_user}}" }, { "key": "password", "value": "{{user_pass}}" }] },
            "description": "Expects HTTP 403 – user1 has read-only access."
          }
        },
        {
          "name": "GET User by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/users/{{userId}}", "host": ["{{base_url}}"], "path": ["api", "users", "{{userId}}"] },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{user_user}}" }, { "key": "password", "value": "{{user_pass}}" }] }
          }
        },
        {
          "name": "UPDATE User (admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe-Updated\",\n  \"email\": \"john.updated@example.com\",\n  \"country\": \"GERMANY\",\n  \"city\": \"Hamburg\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/users/{{userId}}", "host": ["{{base_url}}"], "path": ["api", "users", "{{userId}}"] },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{admin_user}}" }, { "key": "password", "value": "{{admin_pass}}" }] }
          }
        },
        {
          "name": "DELETE User (admin)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{base_url}}/api/users/{{userId}}", "host": ["{{base_url}}"], "path": ["api", "users", "{{userId}}"] },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{admin_user}}" }, { "key": "password", "value": "{{admin_pass}}" }] }
          }
        }
      ]
    },
    {
      "name": "Departments CRUD",
      "item": [
        {
          "name": "GET All Departments",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/departments", "host": ["{{base_url}}"], "path": ["api", "departments"] },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{user_user}}" }, { "key": "password", "value": "{{user_pass}}" }] }
          }
        },
        {
          "name": "GET Departments – paginated (page 0, size 5, sorted by name)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/departments?page=0&size=5&sort=name,asc",
              "host": ["{{base_url}}"],
              "path": ["api", "departments"],
              "query": [
                { "key": "page", "value": "0", "description": "0-based page index" },
                { "key": "size", "value": "5", "description": "Items per page" },
                { "key": "sort", "value": "name,asc", "description": "Field and direction" }
              ]
            },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{user_user}}" }, { "key": "password", "value": "{{user_pass}}" }] },
            "description": "Same Pageable pattern as Users.\n\nOData equivalent: GET /odata/v4/UserDepartmentService/Departments?$top=5&$skip=0&$orderby=name"
          }
        },
        {
          "name": "CREATE Department (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('deptId', json.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Engineering\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/departments", "host": ["{{base_url}}"], "path": ["api", "departments"] },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{admin_user}}" }, { "key": "password", "value": "{{admin_pass}}" }] }
          }
        },
        {
          "name": "GET Department by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/departments/{{deptId}}", "host": ["{{base_url}}"], "path": ["api", "departments", "{{deptId}}"] },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{user_user}}" }, { "key": "password", "value": "{{user_pass}}" }] }
          }
        },
        {
          "name": "UPDATE Department (admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Engineering & Design\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/departments/{{deptId}}", "host": ["{{base_url}}"], "path": ["api", "departments", "{{deptId}}"] },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{admin_user}}" }, { "key": "password", "value": "{{admin_pass}}" }] }
          }
        },
        {
          "name": "DELETE Department (admin)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{base_url}}/api/departments/{{deptId}}", "host": ["{{base_url}}"], "path": ["api", "departments", "{{deptId}}"] },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{admin_user}}" }, { "key": "password", "value": "{{admin_pass}}" }] }
          }
        }
      ]
    },
    {
      "name": "Custom Operations",
      "description": "Equivalents of OData Function and OData Action, implemented as plain REST endpoints.",
      "item": [
        {
          "name": "Get Users Count (Function equivalent)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/users/count", "host": ["{{base_url}}"], "path": ["api", "users", "count"] },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{user_user}}" }, { "key": "password", "value": "{{user_pass}}" }] },
            "description": "Returns the total number of users as a plain integer.\n\nCAP equivalent: GET /odata/v4/UserDepartmentService/getUsersCount()\nReturns: {\"value\": N}"
          }
        },
        {
          "name": "Assign User to Department (Action equivalent)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"departmentId\": \"{{deptId}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/users/{{userId}}/assign-department", "host": ["{{base_url}}"], "path": ["api", "users", "{{userId}}", "assign-department"] },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{admin_user}}" }, { "key": "password", "value": "{{admin_pass}}" }] },
            "description": "Assigns a user to a department. Returns the updated user DTO.\n\nRun 'CREATE User' and 'CREATE Department' first to populate {{userId}} and {{deptId}}.\n\nCAP equivalent: POST /odata/v4/UserDepartmentService/assignUserToDepartment\nBody: {\"userID\": \"...\", \"departmentID\": \"...\"}\nReturns: {\"success\": true, \"message\": \"...\"}"
          }
        }
      ]
    },
    {
      "name": "Validation Errors",
      "description": "Requests that demonstrate validation. Expect HTTP 400.",
      "item": [
        {
          "name": "CREATE User – blank firstName (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john@example.com\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"] },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{admin_user}}" }, { "key": "password", "value": "{{admin_pass}}" }] }
          }
        },
        {
          "name": "CREATE User – invalid email (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"not-an-email\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"] },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{admin_user}}" }, { "key": "password", "value": "{{admin_pass}}" }] }
          }
        }
      ]
    }
  ]
}
