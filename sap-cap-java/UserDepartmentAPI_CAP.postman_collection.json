            "url": { "raw": "{{base_url}}{{service_path}}/Departments({{deptId}})", "host": ["{{base_url}}{{service_path}}"], "path": ["Departments({{deptId}})"] },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{user_user}}" }, { "key": "password", "value": "{{user_pass}}" }] }
          }
        },
        {
          "name": "UPDATE Department – PATCH (admin)",
          "request": {
