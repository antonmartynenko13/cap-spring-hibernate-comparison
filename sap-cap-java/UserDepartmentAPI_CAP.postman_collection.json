            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{admin_user}}" }, { "key": "password", "value": "{{admin_pass}}" }] }
          }
        }
      ]
    },
    {
      "name": "Custom Operations",
      "description": "OData Function (GET, read-only) and OData Action (POST, can mutate state).\nSpring Boot equivalents are in the 'Custom Operations' folder of the Spring Boot collection.",
      "item": [
        {
          "name": "Get Users Count (OData Function)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}{{service_path}}/getUsersCount()",
              "host": ["{{base_url}}{{service_path}}"],
              "path": ["getUsersCount()"]
            },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{user_user}}" }, { "key": "password", "value": "{{user_pass}}" }] },
            "description": "OData Function – read-only, no side effects.\nThe trailing () is part of the OData URI syntax for functions.\nReturns: {\"value\": N}\n\nSpring Boot equivalent: GET /api/users/count"
          }
        },
        {
          "name": "GET Users Count – OData $count (built-in, no custom code)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "text/plain" }],
            "url": {
              "raw": "{{base_url}}{{service_path}}/Users/$count",
              "host": ["{{base_url}}{{service_path}}"],
              "path": ["Users", "$count"]
            },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{user_user}}" }, { "key": "password", "value": "{{user_pass}}" }] },
            "description": "OData built-in $count segment – returns a plain integer (not JSON) with no custom handler required.\nCompare with 'Get Users Count (OData Function)' above which uses a manually declared CDS function + Java handler.\n\nYou can also combine $count with filters, e.g.:\n  /Users/$count?$filter=address/country eq 'GERMANY'\n\nSpring Boot has no equivalent – you would need a custom endpoint."
          }
        },
        {
          "name": "Assign User to Department (OData Action)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userID\": \"{{userId}}\",\n  \"departmentID\": \"{{deptId}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{service_path}}/assignUserToDepartment",
              "host": ["{{base_url}}{{service_path}}"],
              "path": ["assignUserToDepartment"]
            },
            "auth": { "type": "basic", "basic": [{ "key": "username", "value": "{{admin_user}}" }, { "key": "password", "value": "{{admin_pass}}" }] },
            "description": "OData Action – can mutate state. Parameters go in the POST body.\nRun CREATE User and CREATE Department first to populate {{userId}} and {{deptId}}.\n\nSpring Boot equivalent: POST /api/users/{id}/assign-department\nNote: Spring Boot takes the userId in the URL path; CAP takes both IDs in the action body."
          }
        }
      ]
    },
